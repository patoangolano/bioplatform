# PostgreSQL
POSTGRES_USER=bio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=biodb
DATABASE_URL=postgresql+asyncpg://bio:changeme@postgres:5432/biodb

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_SECRET_KEY=changeme
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=https://bio.quackai.com.br

# Caddy (domínio para HTTPS automático via Let's Encrypt)
DOMAIN=bio.quackai.com.br

# Hostinger API (para MCP)
HOSTINGER_API_TOKEN=

# GitHub (para MCP)
GITHUB_TOKEN=

# External APIs
NCBI_API_KEY=

# Monitoring (senha admin do Grafana — stack em infra/monitoring/)
GRAFANA_ADMIN_PASSWORD=changeme

# Frontend (base da API; padrão same-origin /api/v1)
VITE_API_BASE=/api/v1
